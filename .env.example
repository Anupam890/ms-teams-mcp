# Azure AD app registration credentials
TEAMS_TENANT_ID=your-tenant-id
TEAMS_CLIENT_ID=your-client-id

# Auth mode: "device-code" (default, interactive) or "client-credentials" (non-interactive)
# When TEAMS_AUTH_TOKEN is set, auth mode is automatically "token"
TEAMS_AUTH_MODE=device-code

# Only needed for client-credentials mode:
# TEAMS_CLIENT_SECRET=your-client-secret

# Direct auth token (bypasses OAuth flows). Useful for testing or CI.
# When set, TEAMS_TENANT_ID and TEAMS_CLIENT_ID are optional.
# TEAMS_AUTH_TOKEN=eyJ...

# Read-only mode: uses reduced Graph scopes (User.Read.All, Group.Read.All)
# TEAMS_READ_ONLY=true
